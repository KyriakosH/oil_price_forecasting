                    "query": {
                      "kind": "DataQuery",
                      "group": "grafana-postgresql-datasource",
                      "version": "v0",
                      "spec": {
                        "dataset": "oil_price_forecasting",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "WITH latest_run AS (\r\n  SELECT model_run_id\r\n  FROM app.model_runs\r\n  WHERE model_name = '$model_name'\r\n    AND run_status = 'completed'\r\n  ORDER BY finished_at DESC NULLS LAST, model_run_id DESC\r\n  LIMIT 1\r\n),\r\nrecent_preds AS (\r\n  SELECT\r\n    p.prediction_for_date AS time,\r\n    p.actual_close AS \"Actual\",\r\n    p.predicted_close AS \"Predicted\"\r\n  FROM app.predictions p\r\n  JOIN latest_run lr\r\n    ON p.model_run_id = lr.model_run_id\r\n  WHERE p.actual_close IS NOT NULL\r\n  ORDER BY p.prediction_for_date DESC\r\n  LIMIT 7\r\n)\r\nSELECT *\r\nFROM recent_preds\r\nORDER BY time;",
