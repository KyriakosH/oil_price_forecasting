                        "rawQuery": true,
                        "rawSql": "WITH latest_run AS (\r\n  SELECT model_run_id\r\n  FROM app.model_runs\r\n  WHERE model_name = '$model_name'\r\n    AND run_status = 'completed'\r\n  ORDER BY finished_at DESC NULLS LAST, model_run_id DESC\r\n  LIMIT 1\r\n),\r\nlatest_scored_pred AS (\r\n  SELECT\r\n    prediction_for_date,\r\n    predicted_close,\r\n    actual_close\r\n  FROM app.predictions\r\n  WHERE model_run_id = (SELECT model_run_id FROM latest_run)\r\n    AND actual_close IS NOT NULL\r\n  ORDER BY prediction_for_date DESC\r\n  LIMIT 1\r\n)\r\nSELECT\r\n  ROUND(predicted_close::numeric, 2) AS \"Predicted\",\r\n  ROUND(actual_close::numeric, 2) AS \"Actual\",\r\n  ROUND(ABS(predicted_close - actual_close)::numeric, 2) AS \"Error\",\r\n  TO_CHAR(prediction_for_date, 'YYYY-MM-DD') AS \"Date\"\r\nFROM latest_scored_pred;",
