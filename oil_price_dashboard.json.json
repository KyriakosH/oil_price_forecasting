      "panel-2": {
        "kind": "Panel",
        "spec": {
          "id": 2,
          "title": "Daily Sentiment and Article Count",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "grafana-postgresql-datasource",
                      "version": "v0",
                      "spec": {
                        "dataset": "oil_price_forecasting",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "WITH base AS (\r\n  SELECT\r\n    DATE(COALESCE(ar.published_date::timestamp, ar.published_at))::timestamp AS day,\r\n    s.source_name,\r\n    ap.sentiment_score,\r\n    COALESCE(NULLIF(ap.relevance_score, 0), 1.0) AS weight\r\n  FROM app.articles_raw ar\r\n  JOIN app.sources s\r\n    ON ar.source_id = s.source_id\r\n  JOIN app.articles_processed ap\r\n    ON ap.article_id = ar.article_id\r\n  WHERE $__timeFilter(COALESCE(ar.published_date::timestamp, ar.published_at))\r\n    AND ap.sentiment_score IS NOT NULL\r\n    AND (\r\n      '$news_source' = '__all'\r\n      OR s.source_name = '$news_source'\r\n    )\r\n)\r\nSELECT\r\n  day AS time,\r\n  COUNT(*) AS article_count,\r\n  CASE\r\n    WHEN '$sentiment_metric' = 'weighted_avg_sentiment'\r\n      THEN SUM(sentiment_score * weight) / NULLIF(SUM(weight), 0)\r\n    ELSE AVG(sentiment_score)\r\n  END AS sentiment_value\r\nFROM base\r\nGROUP BY day\r\nORDER BY day;",
                        "sql": {
                          "columns": [
                            {
                              "parameters": [],
                              "type": "function"
                            }
